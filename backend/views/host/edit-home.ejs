<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto mt-10 max-w-3xl rounded-lg bg-white p-8 shadow-lg">
      <h1 class="mb-6 text-center text-3xl font-bold text-gray-800"><%= editing ? "Edit" : "Register" %> Your Home on AirBnB</h1>
      <form action="/host/<%= editing ? "edit-home" : "add-home" %>" method="POST"  enctype="multipart/form-data" class="mx-auto max-w-md">
        <input type="hidden" name="id" value="<%= editing ? home._id : '' %>" />
        <input
          type="text"
          name="houseName"
          value="<%= editing ? home.houseName : '' %>"
          placeholder="Enter your House Name"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500"
          required />
        <input
          type="number"
          min="0"
          step="1"
          name="price"
          value="<%= editing ? home.price : '' %>"
          placeholder="Price Per Night"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500"
          required />
        <input
          type="text"
          name="location"
          value="<%= editing ? home.location : '' %>"
          placeholder="Location"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500"
          required />
        <input
          type="number"
          min="0"
          max="5"
          step="0.1"
          name="rating"
          value="<%= editing ? home.rating : '' %>"
          placeholder="Rating"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500"
          required />
        <input
          type="file"
          name="photoUrl"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500" />
          <input
          type="file"
          name="houseRules"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500" />
        <textarea
          name="description"
          rows="4"
          placeholder="Description"
          class="mb-4 w-full rounded-md border px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-500"><%= editing ? home.description : '' %></textarea>
        <input type="submit" value="<%= editing ? "Update Home" : "Add Home" %>" class="w-full rounded-md bg-red-500 py-2 text-white transition duration-300 hover:bg-red-600" />
      </form>
    </main>
  </body>
</html>
