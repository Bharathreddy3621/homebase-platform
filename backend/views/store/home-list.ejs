<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto mt-10 max-w-6xl rounded-lg bg-white p-8 shadow-lg">
      <h2 class="mb-6 text-center text-3xl font-bold text-red-500">
        Here are our registered homes:
      </h2>
      <% if (registeredHomes.length === 0) { %>
        <div class="rounded-lg border border-dashed border-gray-300 bg-gray-50 p-10 text-center text-gray-600">
          No registered homes found.
        </div>
      <% } else { %>
      <div class="flex flex-wrap justify-center gap-6">
        <% registeredHomes.forEach(home => { %>
          <div class="w-full max-w-sm overflow-hidden rounded-lg bg-white shadow-md transition duration-300 hover:shadow-lg">
            <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>" class="h-48 w-full object-cover">
            <div class="p-4">
              <h3 class="mb-2 text-xl font-semibold text-gray-800"><%= home.houseName %></h3>
              <p class="mb-2 text-gray-600"><i class="fas fa-map-marker-alt mr-2"></i><%= home.location %></p>
              <div class="mb-4 flex items-center justify-between">
                <span class="text-lg font-bold text-red-500">Rs<%= home.price %> / night</span>
                <div class="flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="mr-1 h-5 w-5 text-yellow-400">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-gray-700"><%= home.rating %></span>
                </div>
              </div>
              <div class="flex flex-wrap items-center gap-3">
                <a class="inline-flex items-center rounded-md bg-blue-300 px-4 py-2 font-medium text-slate-900 transition hover:bg-blue-400" href="/homes/<%= home._id %>">
                  Details
                </a>
                <%- include('../partials/favourite', { home: home, isLoggedIn: isLoggedIn }) %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <% } %>
    </main>
  </body>
</html>
